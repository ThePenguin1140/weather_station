# Normalize line endings to stop spurious CRLF/LF diffs across tools/platforms.
# All text files are stored as LF in the repository.
* text=auto

# Arduino sources are edited with the Arduino IDE (typically on Windows) — keep
# CRLF in the working tree, but still store them as LF in the repo.
*.ino text eol=crlf
*.h   text eol=crlf

# Explicitly LF for server / config / docs (already the default, but be clear).
*.py   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.cfg  text eol=lf
*.sh   text eol=lf

# Binary assets git must never touch.
*.png  binary
*.jpg  binary
*.jpeg binary
*.pdf  binary
